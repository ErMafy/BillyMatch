generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  photoUrl         String?  @db.Text
  photoTitle       String?
  photoDescription String?
  createdAt        DateTime @default(now())

  players     Player[]
  matchesWon  Match[]  @relation("MatchWinner")
  matchesLost Match[]  @relation("MatchLoser")
}

model Player {
  id               String   @id @default(cuid())
  name             String
  nickname         String?
  photoUrl         String?  @db.Text
  photoTitle       String?
  photoDescription String?
  teamId           String
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model Season {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  matches Match[]
  bets    Bet[]
}

enum MatchMode {
  SETS
  GOALS
}

model Match {
  id            String    @id @default(cuid())
  seasonId      String
  season        Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  playedAt      DateTime  @default(now())
  winnerTeamId  String
  winnerTeam    Team      @relation("MatchWinner", fields: [winnerTeamId], references: [id])
  loserTeamId   String
  loserTeam     Team      @relation("MatchLoser", fields: [loserTeamId], references: [id])
  mode          MatchMode
  winnerScore   Int
  loserScore    Int
  notes         String?
  checksum      String    @unique
  createdAt     DateTime  @default(now())

  bets Bet[]
}

enum PayerMode {
  WINNER
  LOSER
  SPLIT
  MANUAL
}

model Bet {
  id          String    @id @default(cuid())
  seasonId    String
  season      Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  matchId     String?
  match       Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
  description String
  totalCost   Float
  payerMode   PayerMode
  costWinner  Float     @default(0)
  costLoser   Float     @default(0)
  createdAt   DateTime  @default(now())
}

// ─── EL CHILLI BILLY (Trips) ───

enum TripStatus {
  PAST
  UPCOMING
  IDEA
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum MediaFit {
  COVER
  CONTAIN
}

model Trip {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  location    String
  startDate   DateTime
  endDate     DateTime?
  status      TripStatus
  description String
  quote       String?
  createdAt   DateTime   @default(now())

  heroMediaId String?    @unique
  heroMedia   TripMedia? @relation("HeroMedia", fields: [heroMediaId], references: [id])

  media       TripMedia[] @relation("TripGallery")
  locations   TripLocation[]
}

model TripLocation {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  label     String?
  category  String?
  sequence  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tripId])
  @@index([tripId, sequence])
}

model TripMedia {
  id        String    @id @default(cuid())
  tripId    String?
  trip      Trip?     @relation("TripGallery", fields: [tripId], references: [id], onDelete: Cascade)

  kind      MediaKind
  path      String
  caption   String?
  fit       MediaFit  @default(COVER)
  focalX    Int?      // 0..100, default 50
  focalY    Int?      // 0..100, default 50
  createdAt DateTime  @default(now())

  heroOf    Trip?     @relation("HeroMedia")
}
